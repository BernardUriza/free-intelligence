# =============================================================================
# Docker Ignore - Backend Only Image
# =============================================================================
# This keeps the Docker build context small (~100MB instead of 13GB)
# =============================================================================

# Git
.git
.gitignore
.github
.claude

# Frontend apps (NOT needed for backend image)
apps/
packages/

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info
dist
build
eggs
.eggs
lib
lib64
parts
sdist
var
wheels
pip-wheel-metadata
.pytest_cache
.coverage
htmlcov
.tox
.hypothesis

# Virtual environments
venv
env
ENV
.venv

# IDEs
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Project specific
*.log
*.sqlite
*.db
*.h5
/data/
storage/*.mp3
storage/*.wav
storage/corpus.h5
storage/diarization.h5

# Documentation
docs
*.md
!README.md

# Tests
tests
backend/tests
*.test.py
*_test.py

# CI/CD
.github
deploy
pulumi-do
terraform-do
cdk
scripts

# Node (HUGE - always exclude)
node_modules
.npm
.yarn
.pnpm-store
pnpm-lock.yaml
package-lock.json
yarn.lock

# Notebooks
*.ipynb
.ipynb_checkpoints

# Temporary
tmp
temp
*.tmp
*.bak
*.backup

# Docker
Dockerfile*
docker-compose*.yml
docker/

# Tauri/Desktop (NOT needed for backend)
src-tauri

# Other large dirs
.next
out
coverage
playwright-report
