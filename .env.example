# ==================================================
# SINGLE SOURCE OF TRUTH FOR ENVIRONMENT VARIABLES
# ==================================================
# Copy this file to .env in the root directory and fill in the values.
# DO NOT commit the .env file to version control.

# --------------------------------------------------
# Deployment Target Configuration
# --------------------------------------------------
# Controls whether the app runs in cloud (FI-Cloud) or desktop (FI-Edge) mode.
# This affects default URLs, storage paths, and provider selection.
#
# Values:
#   - cloud: Production on Digital Ocean (app.aurity.io)
#   - desktop: Local installable app (default for development)
#
DEPLOYMENT_TARGET=desktop

# --------------------------------------------------
# Backend Configuration (FastAPI)
# These are SECRET and should not be exposed client-side.
# --------------------------------------------------

# FastAPI environment: development, staging, or production
ENVIRONMENT=development
LOG_LEVEL=debug

# CORS allowed origins (comma-separated, no spaces)
# Development: Uses hardcoded localhost origins in backend/app/main.py
# Production: Managed via GitHub Variable ALLOWED_ORIGINS_PROD
#   To update production origins: gh variable set ALLOWED_ORIGINS_PROD --body "origin1,origin2"
# Example: https://app.aurity.io,https://your-netlify-app.netlify.app
ALLOWED_ORIGINS=

# Auth0 Management API Credentials (for backend-to-backend communication)
# Required to fix the API Error 500
AUTH0_DOMAIN=
AUTH0_MANAGEMENT_API_CLIENT_ID=
AUTH0_MANAGEMENT_API_CLIENT_SECRET=
AUTH0_API_AUDIENCE=

# Other backend services (Database, STT, TTS)
# DATABASE_URL=
# Deepgram removed for PHI/HIPAA compliance

# Azure OpenAI - Unified Resource (Single Resource, Multiple Deployments)
# Resource: bernarduriza-openai (rg-vhouse-prod)
# Region: East US (shared with Portfolio backend)
# NOTE: TTS/Whisper + GPT-5 mini all use the same endpoint and API key
AZURE_OPENAI_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_OPENAI_API_KEY=4NwU6IBHTPAsi7dBkPG8akXjb730fglZOq4ks2AQlxJ0mmmX4lyGJQQJ99CAACYeBjFXJ3w3AAABACOG0Jd3

# Azure OpenAI GPT-5 mini Deployment (Chat/LLM)
# Model: gpt-5-mini | Shared with Portfolio backend
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_GPT_API_VERSION=2024-12-01-preview

# Azure OpenAI TTS Deployment (Text-to-Speech)
# Model: tts-hd | Voices: nova (default), alloy, shimmer
AZURE_OPENAI_TTS_DEPLOYMENT=tts-hd
AZURE_OPENAI_TTS_API_VERSION=2025-03-01-preview

# Azure OpenAI Whisper Deployment (Speech-to-Text)
# Model: whisper | Supports all languages, ~25 MB file limit
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
AZURE_OPENAI_WHISPER_API_VERSION=2024-02-01


# --------------------------------------------------
# Frontend Configuration (Next.js)
# These variables are prefixed with NEXT_PUBLIC_ and are safe to be exposed to the browser.
# --------------------------------------------------

# The URL of your Next.js application
NEXT_PUBLIC_BASE_URL=http://localhost:9000

# The URL of your backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Auth0 Credentials (for frontend authentication)
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_SCOPE='openid profile email'
