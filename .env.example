# ==================================================
# SINGLE SOURCE OF TRUTH FOR ENVIRONMENT VARIABLES
# ==================================================
# Copy this file to .env in the root directory and fill in the values.
# DO NOT commit the .env file to version control.

# --------------------------------------------------
# Backend Configuration (FastAPI)
# These are SECRET and should not be exposed client-side.
# --------------------------------------------------

# FastAPI environment: development, staging, or production
ENVIRONMENT=development
LOG_LEVEL=debug

# Auth0 Management API Credentials (for backend-to-backend communication)
# Required to fix the API Error 500
AUTH0_DOMAIN=
AUTH0_MANAGEMENT_API_CLIENT_ID=
AUTH0_MANAGEMENT_API_CLIENT_SECRET=
AUTH0_API_AUDIENCE=

# Other backend services (Database, STT, TTS)
# DATABASE_URL=
# DEEPGRAM_API_KEY=<your_deepgram_api_key>

# Azure OpenAI TTS (Text-to-Speech)
# Required for audio synthesis (voices: nova, alloy, shimmer)
AZURE_OPENAI_TTS_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_TTS_API_KEY=<your_azure_openai_tts_api_key>
AZURE_OPENAI_TTS_API_VERSION=2025-03-01-preview
AZURE_OPENAI_TTS_DEPLOYMENT=tts-hd


# --------------------------------------------------
# Frontend Configuration (Next.js)
# These variables are prefixed with NEXT_PUBLIC_ and are safe to be exposed to the browser.
# --------------------------------------------------

# The URL of your Next.js application
NEXT_PUBLIC_BASE_URL=http://localhost:9000

# The URL of your backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Auth0 Credentials (for frontend authentication)
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_SCOPE='openid profile email'
