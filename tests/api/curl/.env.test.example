# AURITY API Test Environment Variables
# Copia este archivo a .env.test y configura tus valores

# Backend URL
API_BASE_URL=http://localhost:7001

# Auth0 JWT Token
# Obtener de: localStorage.getItem('auth0_token') en app.aurity.io
AUTH_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjEyMyJ9..signature

# Test User IDs
TEST_USER_ID=test-user-$(date +%s)
TEST_PATIENT_ID=patient-test-001
TEST_PROVIDER_ID=provider-test-001

# Audio Fixtures (paths relativos a este directorio)
TEST_AUDIO_FILE=./fixtures/audio/sample_30s.wav
TEST_AUDIO_CHUNK=./fixtures/audio/chunk_5s.wav

# Configuración de tests
TEST_TIMEOUT=30
TEST_RETRY_COUNT=3
TEST_PARALLEL_SESSIONS=10
