    "ToolCallPayload": {
      "additionalProperties": false,
      "description": "One tool invocation, mirroring :class:`fi_runner.backend.ToolCall`.\n\n``input`` may carry PHI and is never placed in telemetry; it stays on the\nwire only because the glass-box panel renders it for the operator.",
      "properties": {
        "name": {
          "type": "string"
        },
        "server": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "input": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "is_error": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "duration_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ],
      "title": "ToolCallPayload",
      "type": "object"
    },
    "TurnResultPayload": {
      "additionalProperties": false,
      "description": "The settled result of a turn, mirroring :class:`fi_runner.backend.TurnResult`.\n\n``model`` is the model that ACTUALLY ran (the retry loop may escalate to the\nfallback), so a UI shows the answer's real provenance instead of guessing at\nthe configured default.",
      "properties": {
        "text": {
          "type": "string"
        },
        "usage": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
