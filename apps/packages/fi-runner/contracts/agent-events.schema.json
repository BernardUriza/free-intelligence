        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "guard_outcomes": {
          "additionalProperties": true,
          "type": "object"
        },
        "tool_calls": {
          "items": {
            "$ref": "#/$defs/ToolCallPayload"
