{
  "$defs": {
    "DoneEvent": {
      "additionalProperties": false,
      "description": "Last frame of a healthy stream.",
      "properties": {
        "type": {
          "const": "done",
          "default": "done",
          "type": "string"
        }
      },
      "title": "DoneEvent",
      "type": "object"
    },
    "ElementEvent": {
      "additionalProperties": false,
      "description": "Announces WHO is answering, before any token arrives.",
      "properties": {
        "type": {
          "const": "element",
          "default": "element",
          "type": "string"
        },
        "element": {
          "$ref": "#/$defs/ElementPayload"
        }
      },
      "required": [
        "element"
      ],
      "title": "ElementEvent",
      "type": "object"
    },
    "ElementPayload": {
      "additionalProperties": false,
      "description": "Which persona/element answered this turn.\n\n``label`` is the composed one-liner (\"53 \u00b7 I \u00b7 Yodo\"); the parts ride\nalongside it so a UI can attribute a bubble without re-parsing that string \u2014\n``name`` is the speaker's name, ``symbol`` the avatar token, ``engine`` the\npersona/engine behind it. Optional: a runner that only knows an id/label\nstill emits a valid frame.",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "symbol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "engine": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "label"
      ],
      "title": "ElementPayload",
      "type": "object"
    },
    "ErrorEvent": {
      "additionalProperties": false,
      "description": "The turn died. Terminal \u2014 no ``done`` follows a fatal error.",
      "properties": {
        "type": {
          "const": "error",
          "default": "error",
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "ErrorEvent",
      "type": "object"
    },
    "GuardMatch": {
      "additionalProperties": true,
      "properties": {
        "index": {
          "type": "integer"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "index",
        "label"
      ],
      "title": "GuardMatch",
      "type": "object"
    },
    "OpenEvent": {
      "additionalProperties": false,
      "description": "First frame of every stream. Carries the id a UI keys concurrent turns on.",
      "properties": {
        "type": {
          "const": "open",
          "default": "open",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "OpenEvent",
      "type": "object"
    },
    "PlanAmendedData": {
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "action": {
          "enum": [
            "insert",
            "replan"
          ],
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "action"
      ],
      "title": "PlanAmendedData",
      "type": "object"
    },
    "PlanAmendedEvent": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "plan_amended",
          "default": "plan_amended",
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/PlanAmendedData"
        }
      },
      "required": [
        "data"
      ],
      "title": "PlanAmendedEvent",
      "type": "object"
    },
    "PlanCancelledData": {
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason": {
          "default": "",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "PlanCancelledData",
      "type": "object"
    },
    "PlanCancelledEvent": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "plan_cancelled",
          "default": "plan_cancelled",
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/PlanCancelledData"
        }
      },
      "required": [
        "data"
      ],
      "title": "PlanCancelledEvent",
      "type": "object"
    },
    "PlanCompletedEvent": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "plan_completed",
          "default": "plan_completed",
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/PlanTerminalData"
        }
      },
      "required": [
        "data"
      ],
      "title": "PlanCompletedEvent",
      "type": "object"
    },
    "PlanData": {
      "additionalProperties": false,
      "properties": {
        "steps": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "steps"
      ],
      "title": "PlanData",
      "type": "object"
    },
    "PlanEvent": {
      "additionalProperties": false,
      "description": "The agent declared its plan. ``steps`` is the checklist a UI renders.",
