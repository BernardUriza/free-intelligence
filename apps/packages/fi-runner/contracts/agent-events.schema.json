        "step_index": {
          "type": "integer"
        },
        "note": {
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "step_index",
        "note"
