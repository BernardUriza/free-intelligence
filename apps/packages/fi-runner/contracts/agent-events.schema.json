    "PlanRejectedData": {
      "additionalProperties": false,
      "description": "A plan guard refused the declared plan before any step ran.",
      "properties": {
        "reason": {
          "type": "string"
        },
        "matched": {
          "items": {
            "$ref": "#/$defs/GuardMatch"
          },
          "type": "array"
        },
        "reinforcement": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "guard": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "reason"
      ],
      "title": "PlanRejectedData",
      "type": "object"
    },
    "PlanRejectedEvent": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "plan_rejected",
          "default": "plan_rejected",
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/PlanRejectedData"
        }
      },
      "required": [
        "data"
      ],
      "title": "PlanRejectedEvent",
      "type": "object"
    },
    "PlanTerminalData": {
      "additionalProperties": false,
      "description": "Counters for the terminal plan frame.\n\nThey default to ``0`` rather than being optional on purpose: a consumer must\nnever receive ``undefined`` here and coerce it silently. The emitter fills\nreal counts whenever the observer ran.",
      "properties": {
        "plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "completed_count": {
          "default": 0,
          "type": "integer"
        },
        "failed_count": {
          "default": 0,
          "type": "integer"
        },
        "cancelled_count": {
          "default": 0,
          "type": "integer"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "PlanTerminalData",
      "type": "object"
    },
    "ResultEvent": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "result",
          "default": "result",
          "type": "string"
        },
        "result": {
          "$ref": "#/$defs/TurnResultPayload"
        }
      },
      "required": [
        "result"
      ],
      "title": "ResultEvent",
      "type": "object"
    },
    "StepDoneData": {
      "additionalProperties": false,
      "description": "``summary`` accompanies a ``done`` step; ``error`` a failed/cancelled one.",
      "properties": {
        "plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "step_index": {
          "type": "integer"
        },
        "status": {
          "enum": [
            "done",
            "failed",
            "cancelled"
          ],
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "step_index",
        "status"
      ],
      "title": "StepDoneData",
      "type": "object"
    },
