{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurity",
  "version": "1.0.21",
  "identifier": "io.aurity.desktop",
  "build": {
    "beforeBuildCommand": "node scripts/build-frontend-if-needed.js",
    "beforeDevCommand": "",
    "frontendDist": "../../aurity/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Aurity - Medical AI Assistant",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "title": "Aurity",
        "width": 400,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": true,
        "url": "splashscreen.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://app.aurity.io https://*.auth0.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/aurity-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Medical",
    "shortDescription": "Medical AI Assistant - 100% Offline",
    "longDescription": "Aurity Desktop is a medical AI assistant that runs entirely on your computer. No cloud required. Your data stays on your device.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null,
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 200
        }
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libsqlite3-0"
        ]
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": [
          "English",
          "Spanish"
        ],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aurity"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/BernardUriza/free-intelligence/releases/latest/download/aurity-desktop-updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA5RTgzMEFFQjVGREVGN0YKUldSLzcvMjFyakRvQ1FocDFIbkRoQ1JlbkdSUEc1QlhZR1F3TzF4NEFJcS9NM3BpVCtQbE9nYk0K"
    }
  }
}