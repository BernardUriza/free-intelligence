{
  "$schema": "https://schema.tauri.app/capability/2.0.0",
  "identifier": "default",
  "description": "Default capabilities for Aurity Desktop - follows principle of least privilege",
  "windows": ["main", "splashscreen"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:event:default",
    "shell:default",
    "process:default"
  ]
}
