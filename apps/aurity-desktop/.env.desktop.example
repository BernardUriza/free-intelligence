# Aurity Desktop Environment Variables
# These are used when building and running the desktop app
#
# Copy this file to .env.desktop and fill in your values:
#   cp .env.desktop.example .env.desktop

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
DEPLOYMENT_TARGET=desktop
NEXT_PUBLIC_DEPLOYMENT_TARGET=desktop

# Backend URL (local sidecar - dynamic port assigned by Tauri)
# Note: This is overridden at runtime by window.__AURITY_BACKEND_URL__
NEXT_PUBLIC_BACKEND_URL=http://localhost:7051

# Ollama (local LLM inference)
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# AUTH0 CONFIGURATION (Native OAuth with Deep Links)
# =============================================================================
# Configure these for production desktop builds with real Auth0 authentication.
# Leave empty or set NEXT_PUBLIC_DESKTOP_OFFLINE=true for offline-only mode.
#
# To get these values:
# 1. Go to Auth0 Dashboard > Applications > Create Application
# 2. Select "Native" as the application type
# 3. In Settings, add to "Allowed Callback URLs": aurity://callback
# 4. Enable "Refresh Token Rotation" in Application Settings
# 5. Copy Domain and Client ID below

NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-native-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://app.aurity.io

# =============================================================================
# OFFLINE MODE
# =============================================================================
# Set to true to bypass Auth0 and use mock authentication (development/offline)
# When false, Auth0 is required but offers fallback to controlled offline mode
NEXT_PUBLIC_DESKTOP_OFFLINE=false
NEXT_PUBLIC_USE_MOCK_AUTH=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_DEMO_MODE=0

# =============================================================================
# DATA STORAGE
# =============================================================================
# User data directory (created on first run with secure permissions)
DATA_DIR=~/.aurity
