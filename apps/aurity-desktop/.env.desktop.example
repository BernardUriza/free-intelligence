# Aurity Desktop Environment Variables
# Copy this file to .env.desktop before building
#
# SECURITY NOTE: This file is a template with SAFE defaults.
# The actual .env.desktop is gitignored to prevent accidental
# commits of authentication bypass settings.

# Deployment target (always desktop for this app)
DEPLOYMENT_TARGET=desktop
NEXT_PUBLIC_DEPLOYMENT_TARGET=desktop

# Backend URL (local sidecar)
NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# Authentication Mode
# - Set to 'true' ONLY for offline desktop builds
# - NEVER enable for cloud deployments
# - Build scripts should explicitly set this based on target
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Demo mode (0 = disabled)
NEXT_PUBLIC_DEMO_MODE=0

# Data directory (will be created on first run)
DATA_DIR=~/.aurity
