# ============================================================================
# AURITY - Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Auth0 Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# IMPORTANT: Development and Production MUST use different values!
# Get these values from your Auth0 dashboard:
# https://manage.auth0.com/dashboard/
#
# For DEVELOPMENT:
#   - Create a separate Auth0 Application (SPA) for local dev
#   - Create a separate Auth0 API with audience: http://localhost:7001/api
#   - Configure Allowed Callback URLs: http://localhost:9000/callback
#   - Configure Allowed Logout URLs: http://localhost:9000
#   - Configure Allowed Web Origins: http://localhost:9000
#
# For PRODUCTION:
#   - Use your production Auth0 Application
#   - Use your production Auth0 API with audience: https://app.aurity.io

# === DEVELOPMENT EXAMPLE ===
NEXT_PUBLIC_AUTH0_DOMAIN=dev-YOUR_TENANT.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=YOUR_DEV_CLIENT_ID
NEXT_PUBLIC_AUTH0_AUDIENCE=http://localhost:7001/api
NEXT_PUBLIC_AUTH0_SCOPE=openid profile email offline_access
NEXT_PUBLIC_BASE_URL=http://localhost:9000

# === PRODUCTION EXAMPLE (use in .env.production) ===
# NEXT_PUBLIC_AUTH0_DOMAIN=prod-YOUR_TENANT.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=YOUR_PROD_CLIENT_ID
# NEXT_PUBLIC_AUTH0_AUDIENCE=https://app.aurity.io
# NEXT_PUBLIC_BASE_URL=https://app.aurity.io

# ----------------------------------------------------------------------------
# Backend API Configuration
# ----------------------------------------------------------------------------
# Development: http://localhost:7001
# Production: https://api.aurity.io
NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Optional: Alternative API base (if different from backend URL)
# NEXT_PUBLIC_API_BASE=http://localhost:7001

# Optional: Timeline API (defaults to backend URL)
# NEXT_PUBLIC_TIMELINE_API_URL=http://localhost:7001/api/workflows/aurity

# ----------------------------------------------------------------------------
# Development Mode (OPTIONAL)
# ----------------------------------------------------------------------------
# Enable mock Auth0 provider (for development without real Auth0)
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Enable auto-login in development
NEXT_PUBLIC_ALLOW_DEV_AUTOLOGIN=false

# Enable demo mode with sample data
NEXT_PUBLIC_DEMO_MODE=0

# Enable mock backend (develop without running real backend)
NEXT_PUBLIC_MOCK_BACKEND=false

# ----------------------------------------------------------------------------
# Superadmin Configuration (OPTIONAL)
# ----------------------------------------------------------------------------
# Comma-separated list of superadmin emails
# These users will have full system access
NEXT_PUBLIC_SUPERADMIN_EMAILS=admin@clinic.local

# ----------------------------------------------------------------------------
# Feature Flags (OPTIONAL)
# ----------------------------------------------------------------------------
# Enable experimental features
NEXT_PUBLIC_ENABLE_VOICE_RECORDING=true
NEXT_PUBLIC_ENABLE_DOCUMENT_UPLOAD=true
NEXT_PUBLIC_ENABLE_WEBSOCKET_SYNC=true

# ----------------------------------------------------------------------------
# Analytics & Monitoring (OPTIONAL)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# ----------------------------------------------------------------------------
# Deployment Target (REQUIRED for multi-target builds)
# ----------------------------------------------------------------------------
# Controls whether the app runs in cloud (FI-Cloud) or desktop (FI-Edge) mode.
# This affects default URLs, storage paths, and provider selection.
#
# Values:
#   - cloud: Production on Digital Ocean (app.aurity.io)
#   - desktop: Local installable app (default for development)
#
NEXT_PUBLIC_DEPLOYMENT_TARGET=desktop

# ----------------------------------------------------------------------------
# Clinic Branding (OPTIONAL)
# ----------------------------------------------------------------------------
# Display name shown in dashboard TV mode, QR check-in, and info bar
NEXT_PUBLIC_CLINIC_NAME=Mi Clínica

# ----------------------------------------------------------------------------
# Deployment Info (OPTIONAL)
# ----------------------------------------------------------------------------
# NODE_ENV=development
# NEXT_PUBLIC_APP_VERSION=0.1.0
# NEXT_PUBLIC_BUILD_ID=

# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# Example 1: Local Development with Mock Auth
# NEXT_PUBLIC_USE_MOCK_AUTH=true
# NEXT_PUBLIC_MOCK_BACKEND=true
# NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Example 2: Local Development with Real Auth0
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-xyz123.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=abc123def456
# NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# Example 3: Production
# NEXT_PUBLIC_AUTH0_DOMAIN=prod-xyz123.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=prod_client_id
# NEXT_PUBLIC_BACKEND_URL=https://api.aurity.io
# NEXT_PUBLIC_BASE_URL=https://app.aurity.io

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env.local to git
# 2. Keep Auth0 credentials secure
# 3. Use different Auth0 tenants for dev/staging/prod
# 4. Rotate credentials regularly
# 5. Limit CORS origins in production
# ============================================================================
