# Auth0 Configuration (Required for OAuth)
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id
NEXT_PUBLIC_SUPERADMIN_EMAILS=admin@example.com

# Backend API URL (Required)
NEXT_PUBLIC_BACKEND_URL=http://localhost:7001

# GitHub Token for Downloads Page (Optional)
# Used to fetch latest release info dynamically from GitHub API
# Only needed for private repositories
# Permissions needed: Contents (read-only), Metadata (read-only)
#
# How to create:
# 1. Go to https://github.com/settings/tokens?type=beta
# 2. Click "Generate new token (fine-grained)"
# 3. Repository access: Only select "free-intelligence"
# 4. Permissions: Contents (Read-only), Metadata (Read-only)
# 5. Copy token and paste below
#
# If not set: Downloads page will use direct GitHub Release links (still works!)
NEXT_PUBLIC_GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXX
