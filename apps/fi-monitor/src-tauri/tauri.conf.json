{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FIMonitor",
  "version": "1.0.2",
  "identifier": "io.aurity.fi-monitor",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "FI Monitor"
    },
    "windows": [
      {
        "label": "main",
        "title": "FI Monitor",
        "width": 420,
        "height": 480,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/OllamaSetup",
      "binaries/python-3.14.0-amd64"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Ollama Tunnel Manager for Aurity",
    "longDescription": "FI Monitor manages the Cloudflare tunnel that exposes your local Ollama instance to the Aurity cloud backend.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "Spanish"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/BernardUriza/free-intelligence/releases/latest/download/fi-monitor-updater.json"
      ],
      "pubkey": "PLACEHOLDER_WILL_BE_REPLACED_AFTER_KEY_GENERATION",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
