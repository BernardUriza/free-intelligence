{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9333"
      ],
      "env": {}
    },
    "azure-cli": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-azure-cli"
      ],
      "env": {}
    },
    "cloudflare-docs": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://docs.mcp.cloudflare.com/mcp"
      ],
      "env": {}
    },
    "cloudflare-observability": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://observability.mcp.cloudflare.com/mcp"
      ],
      "env": {}
    },
    "cloudflare-bindings": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://bindings.mcp.cloudflare.com/mcp"
      ],
      "env": {}
    }
  }
}